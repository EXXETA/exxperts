# npm 12 defaults allow-remote to "none", which blocks the SheetJS CDN tarball
# (xlsx ships current releases only via cdn.sheetjs.com; the npm registry copy
# is a years-old 0.18.x with known vulnerabilities). "root" permits URL
# dependencies declared in this project's own package.json and keeps blocking
# transitive URL dependencies. Install scripts are approved per-package via
# the allowScripts field in package.json.
allow-remote=root
